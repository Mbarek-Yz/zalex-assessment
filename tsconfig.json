{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "./",
    "isolatedModules": true,
    "jsx": "react-native",
    "lib": ["ES2019"],
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "_assets/*": ["./src/assets/*"],
      "_components/*": ["./src/components/*"],
      "_config/*": ["./src/config/*"],
      "_enums/*": ["./src/enums/*"],
      "_env": ["./src/config/env"],
      "_hooks/*": ["./src/hooks/*"],
      "_i18n": ["./src/locales/i18n"],
      "_languages/*": ["./src/locales/languages/*"],
      "_adapters/*": ["./src/adapters/*"],
      "_navigation/*": ["./src/navigation/*"],
      "_screens/*": ["./src/screens/*"],
      "_utils/*": ["./src/utils/*"],
      "_helpers/*": ["./src/helpers/*"],
      "_validation/*": ["./src/validation/*"],
      "_store/*": ["./src/store/*"]
    },
    "strict": true,
    "types": ["jest", "@testing-library/jest-native"]
  },
  "include": ["src/**/*", "**/*.test.ts", "**/*.test.tsx", "__tests__/**/*"],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
